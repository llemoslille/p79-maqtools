omie_estoque/machtools.json

# IDE
.vscode/

# Só descomente se existir pasta experimental na raiz do repo.
# NÃO use "novo_projeto/" solto: isso ignoraria também omie_estoque/novo_projeto/ (código do ETL).
# /novo_projeto/

# Extensões: use *.ext — ".ext" ignora só arquivo com nome exatamente ".ext"
# Descomente só o que fizer sentido (muito *.json/*.yaml pode esconder configs que você quer commitar)
# *.json
# *.yaml
# *.yml
# *.xml
# *.html
# *.css
# *.js
# *.ts
